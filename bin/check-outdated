#!/usr/bin/env ruby
# frozen_string_literal: true

module DependencyFreshnessCheck
  CHECKS = [
    [ "Bundler", [ "bundle", "outdated", "--strict" ] ],
    [ "npm", [ "bin/npm", "outdated" ] ]
  ].freeze

  module_function

  def run(stdout: $stdout, shell_runner: method(:system))
    failed = false

    CHECKS.each do |label, command|
      stdout.puts "==> #{label}: #{command.join(' ')}"
      success = shell_runner.call(*command)
      failed ||= !success
      stdout.puts
    end

    failed ? 1 : 0
  end

  def run_cli
    exit run
  end
end

DependencyFreshnessCheck.run_cli if __FILE__ == $PROGRAM_NAME
