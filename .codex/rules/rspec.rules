# Allow Codex to run stable, non-destructive Routeprint verification targets.
prefix_rule(
    pattern=[
        "make",
        [
            "agent-rspec",
            "agent-test",
            "agent-verify-fast",
            "verify-fast",
            "verify",
            "security",
            "openspec-validate",
        ],
    ],
    decision="allow",
    justification="Stable non-destructive Routeprint verification targets",
)
