# Allow Codex to run stable, non-destructive Routeprint read/check targets.
prefix_rule(
    pattern=[
        "make",
        [
            "agent-state",
            "agent-host-search",
            "agent-rspec",
            "agent-test",
            "agent-frontend-format",
            "agent-frontend-lint",
            "agent-frontend-typecheck",
            "agent-frontend-test",
            "agent-rubocop",
            "agent-verify-fast",
            "harness-check",
            "verify-fast",
            "verify",
            "security",
            "openspec-validate",
        ],
    ],
    decision="allow",
    justification="Stable non-destructive Routeprint verification targets",
)
