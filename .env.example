RAILS_ENV=development
APP_HOST=localhost
APP_PORT=3000
APP_PROTOCOL=http
ACTIVE_STORAGE_SERVICE=local
OURAIRPORTS_AIRPORTS_SOURCE_URL=https://ourairports.com/data/airports.csv
OURAIRPORTS_COUNTRIES_SOURCE_URL=https://ourairports.com/data/countries.csv
CLDR_RELEASE=48.2.1
CLDR_TERRITORIES_SOURCE_URL_TEMPLATE=https://raw.githubusercontent.com/unicode-org/cldr-json/%{release}/cldr-json/cldr-localenames-full/main/%{locale}/territories.json
RAILS_MAX_THREADS=5
PORT=3000
JOB_CONCURRENCY=1
RAILS_LOG_LEVEL=info
REDIS_URL=redis://localhost:6379/1
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=routeprint_development
DB_QUEUE_NAME=routeprint_development_queue
DB_CACHE_NAME=routeprint_cache
DB_CABLE_NAME=routeprint_cable
